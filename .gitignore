# Godot 4+ specific ignores
.godot/
/android/

# Node (godot-mcp local install for Cursor)
# Godot ignores gitignore — node_modules/.gdignore tells the editor not to scan this folder.
node_modules/

# Exported playtest builds
builds/*
!builds/.gitkeep
*.exe

# Local reference clone (Kenney tutorial demo) — assets live in assets/placeholders/kenney/
# Godot ignores gitignore — _tmp_pixel_platformer/.gdignore excludes it from the editor scan.
_tmp_pixel_platformer/
